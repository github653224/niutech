---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostToc from '../../components/PostToc.astro';

// 简单字符串哈希（用于密码保护，非加密用途）
function strHash(str: string): string {
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = ((h << 5) - h + str.charCodeAt(i)) | 0;
  }
  return Math.abs(h).toString(36);
}

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'posts'>;
const post = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, updatedDate, tags, password } = post.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 上一篇 / 下一篇
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const index = allPosts.findIndex((p) => p.slug === post.slug);
const prev = index > 0 ? allPosts[index - 1] : null;
const next = index < allPosts.length - 1 ? allPosts[index + 1] : null;
---

<BaseLayout title={`${title} - 热爱技术的小牛`} description={description}>
  <article class="container-prose py-10">
    <!-- 返回 -->
    <a href={`${base}/`} class="inline-flex items-center gap-1 text-sm mb-8 link-brand">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      返回首页
    </a>

    <!-- 文章头 -->
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight">{title}</h1>
      <p class="mt-3 text-base" style="color: rgb(var(--muted));">{description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm" style="color: rgb(var(--muted));">
        <span><FormattedDate date={pubDate} /></span>
        {updatedDate && <span>· 更新于 <FormattedDate date={updatedDate} /></span>}
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {tags.map((tag) => <a href={`${base}/tags/${tag}`} class="tag-chip">#{tag}</a>)}
          </div>
        )}
      </div>
    </header>

    <!-- 正文（密码保护） -->
    {password ? (
      <div id="password-guard" data-hash={password ? strHash(password) : ''} class="password-guard">
        <div class="password-card">
          <svg class="password-lock-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0110 0v4"/>
          </svg>
          <h3>🔒 受密码保护</h3>
          <p>本文需要输入访问密码才能查看内容</p>
          <div class="password-input-wrap">
            <input type="password" id="pwd-input" placeholder="请输入访问密码…" autocomplete="off" />
            <button id="pwd-btn">验证</button>
          </div>
          <p id="pwd-error" class="password-error"></p>
        </div>
        <!-- 实际正文（默认隐藏） -->
        <div id="post-content" class="prose-custom" style="display:none">
          <Content />
        </div>
      </div>
    ) : (
      <div class="prose-custom">
        <Content />
      </div>
    )}

    <!-- 上一篇 / 下一篇 -->
    <nav class="mt-14 grid gap-4 sm:grid-cols-2">
      {prev ? (
        <a href={`${base}/posts/${prev.slug}`} class="card p-5 hover:border-brand-400">
          <p class="text-xs mb-1" style="color: rgb(var(--muted));">← 上一篇</p>
          <p class="font-semibold">{prev.data.title}</p>
        </a>
      ) : <div />}
      {next ? (
        <a href={`${base}/posts/${next.slug}`} class="card p-5 hover:border-brand-400 text-right">
          <p class="text-xs mb-1" style="color: rgb(var(--muted));">下一篇 →</p>
          <p class="font-semibold">{next.data.title}</p>
        </a>
      ) : <div />}
    </nav>
  </article>

  <!-- 浮动目录 + 回到顶部/底部 -->
  <PostToc />
</BaseLayout>

{password && (
  <script is:inline>
    // 与服务端一致的简单 hash
    function strHash(str) {
      let h = 0;
      for (let i = 0; i < str.length; i++) {
        h = ((h << 5) - h + str.charCodeAt(i)) | 0;
      }
      return Math.abs(h).toString(36);
    }

    (function() {
      const guard = document.getElementById('password-guard');
      if (!guard) return;
      const targetHash = guard.dataset.hash;
      const contentEl = document.getElementById('post-content');
      const input = document.getElementById('pwd-input');
      const btn = document.getElementById('pwd-btn');
      const errorEl = document.getElementById('pwd-error');

      // 检查 sessionStorage 是否已经验证过
      const sessionKey = 'pwd_' + location.pathname;
      const cachedHash = sessionStorage.getItem(sessionKey);

      if (cachedHash && cachedHash === targetHash) {
        unlock();
        return;
      }

      btn.addEventListener('click', verify);
      input.addEventListener('keydown', e => { if (e.key === 'Enter') verify(); });

      function verify() {
        const val = input.value.trim();
        if (!val) { showError('请输入密码'); return; }
        if (strHash(val) === targetHash) {
          sessionStorage.setItem(sessionKey, targetHash);
          unlock();
        } else {
          showError('密码错误，请重试');
          input.value = '';
          input.focus();
        }
      }

      function unlock() {
        const card = guard.querySelector('.password-card');
        if (card) { card.style.display = 'none'; }
        if (contentEl) { contentEl.style.display = ''; }
        errorEl.textContent = '';
      }

      function showError(msg) {
        errorEl.textContent = msg;
        input.classList.add('shake');
        setTimeout(() => input.classList.remove('shake'), 500);
      }
    })();
  </script>
)}

<style is:global>
  .password-guard { position: relative; }
  .password-card {
    max-width: 400px;
    margin: 40px auto;
    padding: 32px 24px;
    text-align: center;
    border-radius: 16px;
    background: rgb(var(--card));
    border: 1px solid rgb(var(--border));
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  .password-lock-icon { color: rgb(var(--brand)); margin-bottom: 12px; }
  .password-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .password-card p { color: rgb(var(--muted)); font-size: 14px; margin: 0 0 20px; }
  .password-input-wrap {
    display: flex;
    gap: 8px;
    max-width: 280px;
    margin: 0 auto;
  }
  .password-input-wrap input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 8px;
    border: 1px solid rgb(var(--border));
    background: rgb(var(--bg));
    color: rgb(var(--fg));
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  .password-input-wrap input:focus { border-color: rgb(var(--brand)); }
  .password-input-wrap button {
    padding: 10px 18px;
    border-radius: 8px;
    background: rgb(var(--brand));
    color: #fff;
    border: none;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .password-input-wrap button:hover { opacity: 0.9; }
  .password-error { color: #ef4444; font-size: 13px; min-height: 20px; margin-top: 10px; }
  @keyframes shake {
    0%,100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }
  .shake { animation: shake 0.35s ease-in-out; }
</style>
