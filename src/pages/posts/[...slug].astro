---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostToc from '../../components/PostToc.astro';

// 简单字符串哈希（用于密码保护，非加密用途）
function strHash(str: string): string {
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = ((h << 5) - h + str.charCodeAt(i)) | 0;
  }
  return Math.abs(h).toString(36);
}

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'posts'>;
const post = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, updatedDate, tags, password, series, seriesOrder } = post.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 上一篇 / 下一篇
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const index = allPosts.findIndex((p) => p.slug === post.slug);
const prev = index > 0 ? allPosts[index - 1] : null;
const next = index < allPosts.length - 1 ? allPosts[index + 1] : null;

// 系列文章：如果当前文章属于某个系列，取该系列所有文章（按 seriesOrder 排序）
let seriesPosts = null;
let seriesCurrentIndex = -1;
let seriesPrev = null;
let seriesNext = null;
if (series) {
  seriesPosts = (await getCollection('posts', ({ data }) => !data.draft && data.series === series))
    .sort((a, b) => {
      const oa = a.data.seriesOrder ?? 999;
      const ob = b.data.seriesOrder ?? 999;
      return oa - ob;
    });
  seriesCurrentIndex = seriesPosts.findIndex((p) => p.slug === post.slug);
  if (seriesCurrentIndex > 0) seriesPrev = seriesPosts[seriesCurrentIndex - 1];
  if (seriesCurrentIndex < seriesPosts.length - 1) seriesNext = seriesPosts[seriesCurrentIndex + 1];
}
const seriesSlug = series || '';
---

<BaseLayout title={`${title} - 热爱技术的小牛`} description={description}>
  <article class="container-prose py-10">
    <!-- 返回 -->
    <a href={`${base}/`} class="inline-flex items-center gap-1 text-sm mb-8 link-brand">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      返回首页
    </a>

    <!-- 文章头 -->
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight">{title}</h1>
      <p class="mt-3 text-base" style="color: rgb(var(--muted));">{description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm" style="color: rgb(var(--muted));">
        <span><FormattedDate date={pubDate} /></span>
        {updatedDate && <span>· 更新于 <FormattedDate date={updatedDate} /></span>}
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {tags.map((tag) => <a href={`${base}/tags/${tag}`} class="tag-chip">#{tag}</a>)}
          </div>
        )}
      </div>
    </header>

    <!-- 正文（密码保护） -->
    {password ? (
      <div id="password-guard" data-hash={password ? strHash(password) : ''} class="password-guard">
        <div class="password-card">
          <svg class="password-lock-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0110 0v4"/>
          </svg>
          <h3>🔒 受密码保护</h3>
          <p>本文需要输入访问密码才能查看内容</p>
          <div class="password-input-wrap">
            <input type="password" id="pwd-input" placeholder="请输入访问密码…" autocomplete="off" />
            <button id="pwd-btn">验证</button>
          </div>
          <p id="pwd-error" class="password-error"></p>
        </div>
        <!-- 实际正文（默认隐藏） -->
        <div id="post-content" class="prose-custom" style="display:none">
          <Content />
        </div>
      </div>
    ) : (
      <div class="prose-custom">
        <Content />
      </div>
    )}

    <!-- 系列导航卡片 -->
    {series && seriesPosts && (
      <div class="series-nav mt-14">
        <div class="series-nav-header">
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            <span class="text-sm font-medium">本文是</span>
            <a href={`${base}/series/${seriesSlug}`} class="text-sm font-bold link-brand">{series}</a>
            <span class="text-sm font-medium">系列第 {seriesOrder ?? seriesCurrentIndex + 1} 篇</span>
          </div>
          <span class="text-xs" style="color: rgb(var(--muted));">{seriesCurrentIndex + 1} / {seriesPosts.length}</span>
        </div>

        <!-- 系列文章列表 -->
        <div class="series-nav-list">
          {seriesPosts.map((p, i) => {
            const isCurrent = p.slug === post.slug;
            const order = p.data.seriesOrder ?? i + 1;
            return (
              <a
                href={isCurrent ? undefined : `${base}/posts/${p.slug}`}
                class={`series-nav-item ${isCurrent ? 'current' : ''}`}
                aria-current={isCurrent ? 'page' : undefined}
              >
                <span class="series-nav-order">{order}</span>
                <span class="series-nav-title">{p.data.title}</span>
                {isCurrent && <span class="series-nav-current">当前</span>}
              </a>
            );
          })}
        </div>

        <!-- 系列内上下篇 -->
        {(seriesPrev || seriesNext) && (
          <div class="series-nav-footer">
            {seriesPrev ? (
              <a href={`${base}/posts/${seriesPrev.slug}`} class="series-nav-link prev">
                <span class="label">← 系列上一篇</span>
                <span class="title">{seriesPrev.data.title}</span>
              </a>
            ) : <div />}
            {seriesNext ? (
              <a href={`${base}/posts/${seriesNext.slug}`} class="series-nav-link next">
                <span class="label">系列下一篇 →</span>
                <span class="title">{seriesNext.data.title}</span>
              </a>
            ) : <div />}
          </div>
        )}

        <div class="series-nav-bottom">
          <a href={`${base}/series/${seriesSlug}`} class="text-sm link-brand">查看完整系列 →</a>
        </div>
      </div>
    )}

    <!-- 上一篇 / 下一篇（全局） -->
    <nav class="mt-14 grid gap-4 sm:grid-cols-2">
      {prev ? (
        <a href={`${base}/posts/${prev.slug}`} class="card p-5 hover:border-brand-400">
          <p class="text-xs mb-1" style="color: rgb(var(--muted));">← 上一篇</p>
          <p class="font-semibold">{prev.data.title}</p>
        </a>
      ) : <div />}
      {next ? (
        <a href={`${base}/posts/${next.slug}`} class="card p-5 hover:border-brand-400 text-right">
          <p class="text-xs mb-1" style="color: rgb(var(--muted));">下一篇 →</p>
          <p class="font-semibold">{next.data.title}</p>
        </a>
      ) : <div />}
    </nav>
  </article>

  <!-- 浮动目录 + 回到顶部/底部 -->
  <PostToc />
</BaseLayout>

{password && (
  <script is:inline>
    // 与服务端一致的简单 hash
    function strHash(str) {
      let h = 0;
      for (let i = 0; i < str.length; i++) {
        h = ((h << 5) - h + str.charCodeAt(i)) | 0;
      }
      return Math.abs(h).toString(36);
    }

    (function() {
      const guard = document.getElementById('password-guard');
      if (!guard) return;
      const targetHash = guard.dataset.hash;
      const contentEl = document.getElementById('post-content');
      const input = document.getElementById('pwd-input');
      const btn = document.getElementById('pwd-btn');
      const errorEl = document.getElementById('pwd-error');

      // 检查 sessionStorage 是否已经验证过
      const sessionKey = 'pwd_' + location.pathname;
      const cachedHash = sessionStorage.getItem(sessionKey);

      if (cachedHash && cachedHash === targetHash) {
        unlock();
        return;
      }

      btn.addEventListener('click', verify);
      input.addEventListener('keydown', e => { if (e.key === 'Enter') verify(); });

      function verify() {
        const val = input.value.trim();
        if (!val) { showError('请输入密码'); return; }
        if (strHash(val) === targetHash) {
          sessionStorage.setItem(sessionKey, targetHash);
          unlock();
        } else {
          showError('密码错误，请重试');
          input.value = '';
          input.focus();
        }
      }

      function unlock() {
        const card = guard.querySelector('.password-card');
        if (card) { card.style.display = 'none'; }
        if (contentEl) { contentEl.style.display = ''; }
        errorEl.textContent = '';
      }

      function showError(msg) {
        errorEl.textContent = msg;
        input.classList.add('shake');
        setTimeout(() => input.classList.remove('shake'), 500);
      }
    })();
  </script>
)}

<style is:global>
  .password-guard { position: relative; }
  .password-card {
    max-width: 400px;
    margin: 40px auto;
    padding: 32px 24px;
    text-align: center;
    border-radius: 16px;
    background: rgb(var(--card));
    border: 1px solid rgb(var(--border));
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  .password-lock-icon { color: rgb(var(--brand)); margin-bottom: 12px; }
  .password-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .password-card p { color: rgb(var(--muted)); font-size: 14px; margin: 0 0 20px; }
  .password-input-wrap {
    display: flex;
    gap: 8px;
    max-width: 280px;
    margin: 0 auto;
  }
  .password-input-wrap input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 8px;
    border: 1px solid rgb(var(--border));
    background: rgb(var(--bg));
    color: rgb(var(--fg));
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  .password-input-wrap input:focus { border-color: rgb(var(--brand)); }
  .password-input-wrap button {
    padding: 10px 18px;
    border-radius: 8px;
    background: rgb(var(--brand));
    color: #fff;
    border: none;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .password-input-wrap button:hover { opacity: 0.9; }
  .password-error { color: #ef4444; font-size: 13px; min-height: 20px; margin-top: 10px; }
  @keyframes shake {
    0%,100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }
  .shake { animation: shake 0.35s ease-in-out; }

  /* ========== 系列导航卡片 ========== */
  .series-nav {
    border: 1px solid rgb(var(--border));
    border-radius: 16px;
    overflow: hidden;
    background: rgb(var(--card));
  }
  .series-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    background: rgb(var(--bg) / 0.5);
    border-bottom: 1px solid rgb(var(--border));
    flex-wrap: wrap;
  }
  .series-nav-list {
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .series-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .series-nav-item:hover { background: rgb(var(--muted) / 0.1); }
  .series-nav-item.current {
    background: rgb(var(--brand) / 0.08);
    border: 1px solid rgb(var(--brand) / 0.3);
    margin: 0 -1px;
  }
  .series-nav-order {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    background: rgb(var(--border));
    color: rgb(var(--muted));
  }
  .series-nav-item.current .series-nav-order {
    background: rgb(var(--brand));
    color: #fff;
  }
  .series-nav-title {
    flex: 1;
    font-size: 14px;
    color: rgb(var(--muted));
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .series-nav-item.current .series-nav-title {
    color: rgb(var(--fg));
    font-weight: 600;
  }
  .series-nav-item:not(.current):hover .series-nav-title {
    color: rgb(var(--brand));
  }
  .series-nav-current {
    flex-shrink: 0;
    font-size: 11px;
    color: rgb(var(--brand));
    background: rgb(var(--brand) / 0.1);
    padding: 2px 8px;
    border-radius: 4px;
  }
  .series-nav-footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    padding: 12px 12px 0;
    border-top: 1px solid rgb(var(--border));
    margin-top: 4px;
  }
  .series-nav-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 12px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .series-nav-link:hover { background: rgb(var(--muted) / 0.1); }
  .series-nav-link.next { text-align: right; }
  .series-nav-link .label {
    font-size: 11px;
    color: rgb(var(--muted));
  }
  .series-nav-link .title {
    font-size: 13px;
    font-weight: 600;
    color: rgb(var(--fg));
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .series-nav-bottom {
    padding: 12px 20px 16px;
    text-align: center;
  }
  @media (max-width: 640px) {
    .series-nav-footer { grid-template-columns: 1fr; }
    .series-nav-link.next { text-align: left; }
  }
</style>
