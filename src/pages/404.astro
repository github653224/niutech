---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="页面未找到 - 热爱技术的小牛">
  <section class="container-prose py-24 text-center">
    <p class="text-7xl font-extrabold text-brand-600 dark:text-brand-400">404</p>
    <h1 class="mt-4 text-2xl font-bold">页面未找到</h1>
    <p class="mt-2" style="color: rgb(var(--muted));">你访问的页面不存在或已被移动。</p>
    <a href={`${base}/`} class="mt-8 inline-flex items-center gap-1.5 rounded-lg bg-brand-600 px-5 py-2.5 text-white font-medium hover:bg-brand-700 transition-colors">
      返回首页
    </a>
  </section>
</BaseLayout>
