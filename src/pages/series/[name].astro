---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.series);
  const seriesNames = new Set<string>();
  allPosts.forEach((p) => seriesNames.add(p.data.series!));

  return [...seriesNames].map((name) => ({
    params: { name },
    props: {
      name,
      posts: allPosts
        .filter((p) => p.data.series === name)
        .sort((a, b) => {
          const oa = a.data.seriesOrder ?? 999;
          const ob = b.data.seriesOrder ?? 999;
          return oa - ob;
        }),
    },
  }));
}

const { name, posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const seriesSlug = encodeURIComponent(name);
---

<BaseLayout title={`${name} - 系列 - 热爱技术的小牛`} description={`「${name}」系列，共 ${posts.length} 篇文章`}>
  <section class="container-prose py-10">
    <!-- 返回 -->
    <a href={`${base}/series`} class="inline-flex items-center gap-1 text-sm mb-8 link-brand">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      全部系列
    </a>

    <!-- 系列头部 -->
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm mb-2" style="color: rgb(var(--muted));">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        <span>系列专栏</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">{name}</h1>
      <p class="mt-2 text-base" style="color: rgb(var(--muted));">共 {posts.length} 篇文章</p>

      <!-- 进度条 -->
      <div class="mt-4 flex items-center gap-3">
        <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background-color: rgb(var(--border));">
          <div class="h-full rounded-full bg-brand-500" style={`width: 100%`}></div>
        </div>
        <span class="text-sm font-medium" style="color: rgb(var(--muted));">{posts.length} / {posts.length}</span>
      </div>
    </header>

    <!-- 文章列表 -->
    <div class="space-y-3">
      {posts.map((post, i) => (
        <a href={`${base}/posts/${post.slug}`} class="series-item block card p-5 hover:border-brand-400 hover:shadow-md transition-all group">
          <div class="flex items-start gap-4">
            <!-- 序号 -->
            <div class="shrink-0 flex items-center justify-center w-9 h-9 rounded-full bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400 font-bold text-sm">
              {post.data.seriesOrder ?? i + 1}
            </div>
            <!-- 内容 -->
            <div class="flex-1 min-w-0">
              <h3 class="font-bold tracking-tight group-hover:text-brand-600 transition-colors">{post.data.title}</h3>
              <p class="mt-1 text-sm line-clamp-2" style="color: rgb(var(--muted));">{post.data.description}</p>
              <div class="mt-2 flex flex-wrap items-center gap-3 text-xs" style="color: rgb(var(--muted));">
                <span><FormattedDate date={post.data.pubDate} /></span>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag-chip">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
            <!-- 箭头 -->
            <svg class="shrink-0 h-5 w-5 mt-2 opacity-0 group-hover:opacity-100 transition-opacity" style="color: rgb(var(--brand));" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
