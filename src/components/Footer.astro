---
import { SITE_TITLE, AUTHOR } from '../consts';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mt-20 border-t" style="border-color: rgb(var(--border));">
  <div class="container-wide py-6 flex flex-wrap items-center justify-between gap-4">
    <!-- 左：版权 -->
    <p class="text-sm" style="color: rgb(var(--muted));">
      &copy; {year} {SITE_TITLE} · 用心记录技术成长
    </p>

    <!-- 右：二维码 + GitHub -->
    <div class="flex items-center gap-4 text-sm">
      <!-- 公众号 -->
      <button class="footer-qr" data-qr="wechat" title="点击查看公众号二维码">
        <img src={`${base}/media/images/wechat-qrcode.jpg`} alt="微信公众号" loading="lazy" />
        <span class="footer-qr-label">公众号</span>
      </button>
      <!-- 视频号 -->
      <button class="footer-qr" data-qr="video" title="点击查看视频号二维码">
        <img src={`${base}/media/images/video-qrcode.jpg`} alt="视频号" loading="lazy" />
        <span class="footer-qr-label">视频号</span>
      </button>
      <!-- GitHub -->
      <a href={AUTHOR.social.github} target="_blank" rel="noopener" class="link-brand inline-flex items-center gap-1.5">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.21 3.44 9.63 8.21 11.19.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.72-4.04-1.59-4.04-1.59-.55-1.38-1.34-1.75-1.34-1.75-1.09-.74.08-.73.08-.73 1.21.08 1.84 1.23 1.84 1.23 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.58-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.23-3.17-.12-.3-.53-1.51.12-3.15 0 0 1-.32 3.3 1.21.96-.26 1.98-.39 3-.4 1.02.01 2.04.14 3 .4 2.28-1.53 3.28-1.21 3.28-1.21.65 1.64.24 2.85.12 3.15.77.83 1.23 1.88 1.23 3.17 0 4.54-2.81 5.53-5.49 5.83.43.36.81 1.08.81 2.18 0 1.58-.01 2.85-.01 3.24 0 .32.22.7.83.58C20.57 21.91 24 17.5 24 12.29 24 5.78 18.63.5 12 .5z" /></svg>
        GitHub
      </a>
      <!-- RSS -->
      <a href={`${base}/rss.xml`} target="_blank" rel="noopener" class="link-brand inline-flex items-center gap-1.5" title="RSS 订阅">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg>
        RSS
      </a>
    </div>
  </div>
</footer>

<!-- 二维码大图模态框 -->
<div id="qr-modal" class="qr-modal">
  <div class="qr-modal-backdrop"></div>
  <div class="qr-modal-content">
    <button class="qr-modal-close" aria-label="关闭">&times;</button>
    <img id="qr-modal-img" src="" alt="二维码" />
    <p id="qr-modal-text">扫码关注</p>
  </div>
</div>

<script is:inline>
  (function() {
    const modal = document.getElementById('qr-modal');
    const modalImg = document.getElementById('qr-modal-img');
    const modalText = document.getElementById('qr-modal-text');
    const closeBtn = modal.querySelector('.qr-modal-close');
    const backdrop = modal.querySelector('.qr-modal-backdrop');
    const base = document.documentElement.dataset.base || '';

    const qrData = {
      wechat: { src: base + '/media/images/wechat-qrcode.jpg', label: '扫码关注微信公众号' },
      video: { src: base + '/media/images/video-qrcode.jpg', label: '扫码关注视频号' },
    };

    document.querySelectorAll('.footer-qr').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const key = btn.dataset.qr;
        const info = qrData[key];
        if (!info) return;
        modalImg.src = info.src;
        modalText.textContent = info.label;
        modal.classList.add('show');
        document.body.style.overflow = 'hidden';
      });
    });

    function close() {
      modal.classList.remove('show');
      document.body.style.overflow = '';
    }
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('show')) close();
    });
  })();
</script>

<style is:global>
  .footer-qr {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    text-decoration: none;
  }
  .footer-qr > img {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    border: 1px solid rgb(var(--border));
    object-fit: cover;
    transition: opacity 0.15s;
  }
  .footer-qr:hover > img { opacity: 0.7; }
  .footer-qr-label {
    font-size: 12px;
    color: rgb(var(--muted));
  }

  /* 大图模态框 */
  .qr-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .qr-modal.show {
    display: flex;
    animation: qr-fade 0.2s ease;
  }
  @keyframes qr-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .qr-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
  }
  .qr-modal-content {
    position: relative;
    padding: 24px;
    background: rgb(var(--card));
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    text-align: center;
    animation: qr-zoom 0.2s cubic-bezier(0.16,1,0.3,1);
  }
  @keyframes qr-zoom {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  .qr-modal-content img {
    width: min(320px, 80vw);
    height: auto;
    border-radius: 10px;
    display: block;
  }
  .qr-modal-content p {
    margin: 14px 0 0;
    font-size: 14px;
    color: rgb(var(--muted));
  }
  .qr-modal-close {
    position: absolute;
    top: -12px;
    right: -12px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: rgb(var(--card));
    color: rgb(var(--fg));
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qr-modal-close:hover { background: rgb(var(--muted) / 0.1); }

  @media (max-width: 640px) {
    .footer-qr-label { display: none; }
  }
</style>
