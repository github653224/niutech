---
// 公共底部组件 — 公众号 + 视频号二维码
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
  <div class="footer-qr-group">
    <!-- 公众号 -->
    <a class="footer-qr-item" href="javascript:void(0)" title="关注微信公众号">
      <img src={`${base}/media/images/wechat-qrcode.jpg`} alt="微信公众号" loading="lazy" />
      <span class="footer-qr-label">公众号</span>
    </a>
    <!-- 视频号 -->
    <a class="footer-qr-item" href="javascript:void(0)" title="关注视频号">
      <img src={`${base}/media/images/video-qrcode.jpg`} alt="视频号" loading="lazy" />
      <span class="footer-qr-label">视频号</span>
    </a>
  </div>
  <p class="footer-copy">&copy; {new Date().getFullYear()} 热爱技术的小牛 · 用心记录技术成长</p>
</footer>

<style is:global>
  .site-footer {
    border-top: 1px solid rgb(var(--border));
    background: rgb(var(--card));
    padding: 24px 20px;
    text-align: center;
  }
  .footer-qr-group {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-bottom: 16px;
  }
  .footer-qr-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .footer-qr-item:hover {
    transform: translateY(-4px);
  }
  .footer-qr-item img {
    width: 100px;
    height: 100px;
    border-radius: 10px;
    border: 1px solid rgb(var(--border));
    object-fit: cover;
  }
  .footer-qr-label {
    font-size: 12px;
    color: rgb(var(--muted));
  }
  .footer-copy {
    font-size: 12px;
    color: rgb(var(--muted));
    opacity: 0.7;
    margin: 0;
  }

  @media (max-width: 480px) {
    .footer-qr-group { gap: 16px; }
    .footer-qr-item img { width: 80px; height: 80px; }
  }
</style>
