---
// 搜索弹窗组件 — 客户端全文搜索
// 快捷键 Cmd/Ctrl+K 打开，ESC 关闭，上下箭头选择
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- 搜索触发按钮 -->
<button id="search-trigger" class="search-trigger" aria-label="搜索文章">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
  </svg>
  <span class="search-trigger-text hidden md:inline">搜索</span>
  <kbd class="search-kbd hidden md:inline-flex">⌘K</kbd>
</button>

<!-- 搜索弹窗 -->
<div id="search-overlay" class="search-overlay">
  <div class="search-modal">
    <!-- 搜索输入 -->
    <div class="search-input-wrap">
      <svg class="search-input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
      </svg>
      <input id="search-input" type="text" placeholder="搜索文章标题、标签、内容…" autocomplete="off" spellcheck="false" />
      <button id="search-close" class="search-close-btn" aria-label="关闭">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- 搜索结果 -->
    <div id="search-results" class="search-results">
      <div class="search-hint" id="search-hint">
        <p>输入关键词搜索文章</p>
        <p class="search-hint-sub">支持标题、描述、标签、正文搜索</p>
      </div>
    </div>

    <!-- 底部提示 -->
    <div class="search-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> 导航</span>
      <span><kbd>↵</kbd> 打开</span>
      <span><kbd>esc</kbd> 关闭</span>
    </div>
  </div>
</div>

<script>
  const trigger = document.getElementById('search-trigger');
  const overlay = document.getElementById('search-overlay');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('search-results');
  const hintEl = document.getElementById('search-hint');
  const closeBtn = document.getElementById('search-close');
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');

  let searchData: any[] | null = null;
  let loading = false;
  let activeIndex = -1;
  let currentResults: any[] = [];

  // ===== 打开/关闭 =====
  function open() {
    overlay.classList.add('show');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input.focus(), 50);
  }
  function close() {
    overlay.classList.remove('show');
    document.body.style.overflow = '';
    input.value = '';
    resultsEl.innerHTML = '';
    if (hintEl) {
      resultsEl.appendChild(hintEl);
      hintEl.style.display = '';
    }
    activeIndex = -1;
  }

  trigger.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) close();
  });

  // 快捷键
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      overlay.classList.contains('show') ? close() : open();
    }
    if (e.key === 'Escape' && overlay.classList.contains('show')) {
      close();
    }
    if (!overlay.classList.contains('show')) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, currentResults.length - 1);
      updateActive();
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, 0);
      updateActive();
    }
    if (e.key === 'Enter' && activeIndex >= 0 && currentResults[activeIndex]) {
      e.preventDefault();
      window.location.href = base + '/posts/' + currentResults[activeIndex].slug + '/';
    }
  });

  function updateActive() {
    const items = resultsEl.querySelectorAll('.search-item');
    items.forEach((item, i) => {
      item.classList.toggle('active', i === activeIndex);
    });
    const active = items[activeIndex] as HTMLElement;
    if (active) active.scrollIntoView({ block: 'nearest' });
  }

  // ===== 加载搜索索引 =====
  async function loadData() {
    if (searchData || loading) return;
    loading = true;
    try {
      const res = await fetch(base + '/search-index.json');
      searchData = await res.json();
    } catch (err) {
      console.error('搜索索引加载失败', err);
    }
    loading = false;
  }

  // ===== 搜索逻辑 =====
  function search(query: string) {
    if (!searchData) return [];
    const q = query.toLowerCase().trim();
    if (!q) return [];
    const terms = q.split(/\s+/);

    const scored = searchData.map((post) => {
      const title = (post.title || '').toLowerCase();
      const desc = (post.description || '').toLowerCase();
      const tags = (post.tags || []).join(' ').toLowerCase();
      const body = (post.body || '').toLowerCase();
      const category = (post.category || '').toLowerCase();

      let score = 0;
      for (const term of terms) {
        if (title.includes(term)) score += 10;
        if (tags.includes(term)) score += 6;
        if (category.includes(term)) score += 5;
        if (desc.includes(term)) score += 3;
        if (body.includes(term)) score += 1;
      }

      return { ...post, score };
    });

    return scored
      .filter((p) => p.score > 0)
      .sort((a, b) => {
        // 置顶优先
        if (a.pinned !== b.pinned) return b.pinned ? 1 : -1;
        return b.score - a.score;
      })
      .slice(0, 12);
  }

  // 高亮关键词
  function highlight(text: string, query: string): string {
    if (!query) return text;
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
    let result = text;
    for (const term of terms) {
      const regex = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      result = result.replace(regex, '<mark>$1</mark>');
    }
    return result;
  }

  // 截取摘要
  function snippet(body: string, query: string, maxLen = 100): string {
    if (!body) return '';
    const lower = body.toLowerCase();
    const q = query.toLowerCase().trim();
    if (!q) return body.slice(0, maxLen) + '…';
    const idx = lower.indexOf(q.split(/\s+/)[0]);
    if (idx < 0) return body.slice(0, maxLen) + '…';
    const start = Math.max(0, idx - 30);
    const end = Math.min(body.length, start + maxLen);
    return (start > 0 ? '…' : '') + body.slice(start, end) + (end < body.length ? '…' : '');
  }

  // ===== 渲染结果 =====
  function render(query: string) {
    currentResults = search(query);
    activeIndex = -1;

    if (!query.trim()) {
      resultsEl.innerHTML = '';
      if (hintEl) {
        resultsEl.appendChild(hintEl);
        hintEl.style.display = '';
      }
      return;
    }

    if (currentResults.length === 0) {
      resultsEl.innerHTML = `<div class="search-empty"><p>未找到与「${escapeHtml(query)}」相关的文章</p><p class="search-hint-sub">试试其他关键词？</p></div>`;
      return;
    }

    resultsEl.innerHTML = currentResults
      .map((post, i) => {
        const tagsHtml = (post.tags || [])
          .slice(0, 3)
          .map((t: string) => `<span class="search-tag">#${escapeHtml(t)}</span>`)
          .join('');
        const snippetText = post.description
          ? highlight(escapeHtml(post.description), query)
          : highlight(escapeHtml(snippet(post.body, query)), query);

        return `<a href="${base}/posts/${post.slug}/" class="search-item${i === 0 ? ' active' : ''}" data-index="${i}">
          <div class="search-item-main">
            <span class="search-item-title">${highlight(escapeHtml(post.title), query)}</span>
            ${post.pinned ? '<span class="search-pin">📌</span>' : ''}
          </div>
          <div class="search-item-desc">${snippetText}</div>
          ${tagsHtml ? `<div class="search-item-tags">${tagsHtml}</div>` : ''}
          <span class="search-item-date">${post.pubDate}</span>
        </a>`;
      })
      .join('');

    activeIndex = 0;
    updateActive();
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ===== 输入监听 =====
  let debounceTimer: number;
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(() => {
      render(input.value);
    }, 150);
  });

  // 首次打开时加载索引
  trigger.addEventListener('click', loadData, { once: true });
</script>

<style is:global>
  /* 搜索触发按钮 */
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 13px;
    color: rgb(var(--muted));
    background: transparent;
    border: 1px solid rgb(var(--border));
    cursor: pointer;
    transition: all 0.15s;
  }
  .search-trigger:hover {
    color: rgb(var(--brand));
    border-color: rgb(var(--brand));
  }
  .search-kbd {
    font-size: 11px;
    padding: 1px 5px;
    border-radius: 4px;
    background: rgb(var(--muted) / 0.1);
    border: 1px solid rgb(var(--border));
    font-family: ui-monospace, monospace;
    line-height: 1.4;
  }

  /* 搜索弹窗遮罩 */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  .search-overlay.show {
    display: flex;
    animation: search-fade-in 0.15s ease;
  }
  @keyframes search-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* 搜索弹窗 */
  .search-modal {
    width: 90%;
    max-width: 640px;
    background: rgb(var(--card));
    border: 1px solid rgb(var(--border));
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    animation: search-slide-in 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes search-slide-in {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* 搜索输入区 */
  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid rgb(var(--border));
  }
  .search-input-icon {
    color: rgb(var(--muted));
    flex-shrink: 0;
  }
  .search-input-wrap input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 16px;
    color: rgb(var(--fg));
  }
  .search-input-wrap input::placeholder {
    color: rgb(var(--muted));
  }
  .search-close-btn {
    flex-shrink: 0;
    padding: 4px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: rgb(var(--muted));
    cursor: pointer;
    transition: all 0.15s;
  }
  .search-close-btn:hover {
    color: rgb(var(--fg));
    background: rgb(var(--muted) / 0.1);
  }

  /* 搜索结果区 */
  .search-results {
    max-height: 50vh;
    overflow-y: auto;
    padding: 8px;
  }
  .search-results::-webkit-scrollbar { width: 6px; }
  .search-results::-webkit-scrollbar-thumb {
    background: rgb(var(--border));
    border-radius: 3px;
  }

  .search-hint {
    text-align: center;
    padding: 40px 20px;
    color: rgb(var(--muted));
  }
  .search-hint p { margin: 0; font-size: 15px; }
  .search-hint-sub {
    margin-top: 6px !important;
    font-size: 13px !important;
    opacity: 0.7;
  }

  .search-empty {
    text-align: center;
    padding: 40px 20px;
    color: rgb(var(--muted));
  }
  .search-empty p { margin: 0; font-size: 15px; }

  /* 单条搜索结果 */
  .search-item {
    display: block;
    padding: 12px 14px;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
    position: relative;
  }
  .search-item.active {
    background: rgb(var(--brand) / 0.08);
  }
  .search-item-main {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .search-item-title {
    font-size: 14px;
    font-weight: 600;
    color: rgb(var(--fg));
    line-height: 1.4;
  }
  .search-pin { font-size: 12px; }
  .search-item-desc {
    margin-top: 4px;
    font-size: 13px;
    color: rgb(var(--muted));
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .search-item-tags {
    margin-top: 6px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .search-tag {
    font-size: 11px;
    color: rgb(var(--brand));
    background: rgb(var(--brand) / 0.06);
    padding: 1px 6px;
    border-radius: 4px;
  }
  .search-item-date {
    position: absolute;
    top: 12px;
    right: 14px;
    font-size: 11px;
    color: rgb(var(--muted));
    opacity: 0.6;
  }

  /* 高亮 */
  .search-item mark {
    background: rgb(var(--brand) / 0.2);
    color: rgb(var(--brand));
    border-radius: 2px;
    padding: 0 1px;
  }

  /* 底部提示 */
  .search-footer {
    display: flex;
    gap: 16px;
    padding: 10px 20px;
    border-top: 1px solid rgb(var(--border));
    font-size: 12px;
    color: rgb(var(--muted));
  }
  .search-footer kbd {
    display: inline-block;
    padding: 1px 5px;
    margin: 0 2px;
    border-radius: 4px;
    background: rgb(var(--muted) / 0.1);
    border: 1px solid rgb(var(--border));
    font-family: ui-monospace, monospace;
    font-size: 11px;
  }

  @media (max-width: 640px) {
    .search-modal {
      width: 95%;
      border-radius: 12px;
    }
    .search-footer {
      display: none;
    }
    .search-item-date {
      display: none;
    }
  }
</style>
